    // Outputs
    wire        complete;
    wire signed [31:0] o0;
    wire signed [31:0] y;

    // Instantiate inference (single neuron variant)
    inference #(
        .IMG_HEIGHT(IMG_HEIGHT),
        .IMG_WIDTH (IMG_WIDTH),
        .NO_KERNELS(NO_KERNELS),
        .KERNEL_SIZE(KERNEL_SIZE),
        .MAXPOOL_KERNEL(MAXPOOL_KERNEL),
        .NO_NEURONS(1)
    ) dut (
        .clk(clk),
        .rst_n(rst_n),
        .enable(enable),
        .img(img),
        .kernels(kernels),
        .complete(complete),
        .o0(o0),
        .y(y)
    );

    // Bring in generated initial assignments for img[] and kernels[]
    // Run tools/gen_initial_block.py to create src/initial_block.svfrag
    `include "initial_block.svfrag"

    // Drive LEDs with lower 10 bits of o0
    assign LEDR = o0[9:0];

    // 7-seg hex display (active-low on DE1-SoC)
    function automatic [6:0] hex7(input logic [3:0] nib);
        case (nib)
            4'h0: hex7 = 7'b1000000;
            4'h1: hex7 = 7'b1111001;
            4'h2: hex7 = 7'b0100100;
            4'h3: hex7 = 7'b0110000;
            4'h4: hex7 = 7'b0011001;
            4'h5: hex7 = 7'b0010010;
            4'h6: hex7 = 7'b0000010;
            4'h7: hex7 = 7'b1111000;
            4'h8: hex7 = 7'b0000000;
            4'h9: hex7 = 7'b0010000;
            4'hA: hex7 = 7'b0001000;
            4'hB: hex7 = 7'b0000011;
            4'hC: hex7 = 7'b1000110;
            4'hD: hex7 = 7'b0100001;
            4'hE: hex7 = 7'b0000110;
            4'hF: hex7 = 7'b0001110;
            default: hex7 = 7'b1111111;
        endcase
    endfunction

    // Show integer part (bits 31:16) on HEX3..HEX0 (nibbles)
    assign HEX0 = hex7(o0[19:16]);
    assign HEX1 = hex7(o0[23:20]);
    assign HEX2 = hex7(o0[27:24]);
    assign HEX3 = hex7(o0[31:28]);
    // Show fractional part (bits 15:8) on HEX5..HEX4
    assign HEX4 = hex7(o0[11:8]);
    assign HEX5 = hex7(o0[15:12]);

endmodule
